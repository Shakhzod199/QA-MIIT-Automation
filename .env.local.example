# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and never committed.

# GitHub Personal Access Token with Actions read/write (and Contents read)
# on the repo below. Used server-side only - never sent to the browser.
GITHUB_TOKEN=

# Repo that hosts the Playwright tests + GitHub Actions workflows
# (the QAutomation project itself, once pushed to GitHub).
GITHUB_OWNER=
GITHUB_REPO=

# Dashboard user accounts + sessions are stored in Supabase (see supabase/schema.sql).
# Server-only — never prefix the service role key with NEXT_PUBLIC_ or use it
# in a "use client" component; it bypasses Row Level Security entirely.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# First admin account: after running supabase/schema.sql, create it with
#   node --env-file=.env.local scripts/seed-admin.mjs <username> <password>

# Signs the session cookie (HMAC) so middleware can verify a logged-in user
# on every request without a Supabase round-trip. Any long random string —
# generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Changing this instantly logs everyone out (all existing cookies fail signature check).
SESSION_SECRET=

# Telegram alerts (sent for every run result). See the Telegram Alerts page.
# Bot token from @BotFather; chat id from the bot's getUpdates response.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Shared secret so an external cron can call /api/notify?secret=...
NOTIFY_SECRET=change-this-to-a-random-secret
